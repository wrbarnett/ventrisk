import streamlit as st
import pandas as pd
import numpy as np
import itertools
from sklearn.naive_bayes import CategoricalNB

# Page config

st.set_page_config(page_title="VentRisk", layout="wide")

st.markdown("# 🧬 VentRisk")
st.markdown("*Combinatorial Risk Estimation for Ventilator-Associated Events*")

# File paths

TRAIN_FILE = "vae_186_train.csv"
TEST_FILE = "vae_186_test.csv"  # optional

# Variables

FEATURES = ["ltac", "dm", "chf", "cad", "lung", "opsite", "timecat2"]
TARGET = "status"
POS_LABEL = "1"

FEATURE_LABELS = {
    "ltac": "Admitted from LTAC",
    "dm": "DM",
    "chf": "CHF",
    "cad": "CAD",
    "lung": "COPD",
    "opsite": "Intubated in optimal site (i.e. ICU or OR)",
    "timecat2": "Intubated for less than 7 days"
}

YES_NO_MAP = {
    "0": "No",
    "1": "Yes",
    0: "No",
    1: "Yes",
    "False": "No",
    "True": "Yes",
    False: "No",
    True: "Yes"
}

# Helpers

def pretty_level(val):
    """Convert common binary values to Yes/No for display."""
    return YES_NO_MAP.get(val, str(val))


@st.cache_data
def load_data(train_file, test_file=None):
    train = pd.read_csv(train_file)

    test = None
    if test_file is not None:
        try:
            test = pd.read_csv(test_file)
        except Exception:
            test = None

    return train, test


@st.cache_data
def prepare_training_data(train_df):
    train = train_df.copy()

    # Outcome
    train[TARGET] = train[TARGET].astype(str).str.strip()
    class_labels = sorted(train[TARGET].dropna().unique())

    train[TARGET] = train[TARGET].astype(
        pd.CategoricalDtype(categories=class_labels)
    )
    y_train = train[TARGET].cat.codes

    # Predictors
    category_levels = {}
    for col in FEATURES:
        train[col] = train[col].astype(str).str.strip()
        levels = sorted(train[col].dropna().unique())
        category_levels[col] = levels
        train[col] = train[col].astype(
            pd.CategoricalDtype(categories=levels)
        )

    X_train = pd.DataFrame(
        {col: train[col].cat.codes for col in FEATURES},
        index=train.index
    )

    return train, X_train, y_train, class_labels, category_levels


@st.cache_resource
def fit_model(X_train, y_train):
    model = CategoricalNB()
    model.fit(X_train, y_train)
    return model


def encode_profile(profile_dict, category_levels):
    profile_df = pd.DataFrame([profile_dict])

    for col in FEATURES:
        profile_df[col] = profile_df[col].astype(str).str.strip()
        profile_df[col] = profile_df[col].astype(
            pd.CategoricalDtype(categories=category_levels[col])
        )

    X_profile = pd.DataFrame(
        {col: profile_df[col].cat.codes for col in FEATURES},
        index=profile_df.index
    )

    return profile_df, X_profile


def predict_profile_risk(model, X_profile, class_labels, pos_label="1"):
    if pos_label not in class_labels:
        raise ValueError(
            f"Positive label '{pos_label}' not found in class labels: {class_labels}"
        )

    pos_idx = class_labels.index(pos_label)
    pred_class_idx = model.predict(X_profile)[0]
    pred_probs = model.predict_proba(X_profile)[0]

    return {
        "predicted_class": class_labels[pred_class_idx],
        "predicted_risk": pred_probs[pos_idx],
        "all_probabilities": {
            class_labels[i]: pred_probs[i] for i in range(len(class_labels))
        }
    }


@st.cache_data
def build_all_combinations(category_levels):
    all_combos = list(itertools.product(*[category_levels[col] for col in FEATURES]))
    combo_df = pd.DataFrame(all_combos, columns=FEATURES)
    return combo_df


def score_all_combinations(model, combo_df, category_levels, class_labels, pos_label="1"):
    df = combo_df.copy()

    for col in FEATURES:
        df[col] = df[col].astype(str).str.strip()
        df[col] = df[col].astype(
            pd.CategoricalDtype(categories=category_levels[col])
        )

    X_combo = pd.DataFrame(
        {col: df[col].cat.codes for col in FEATURES},
        index=df.index
    )

    pos_idx = class_labels.index(pos_label)
    probs = model.predict_proba(X_combo)[:, pos_idx]
    preds = model.predict(X_combo)

    df["predicted_class"] = [class_labels[i] for i in preds]
    df["predicted_risk"] = probs

    return df.sort_values("predicted_risk", ascending=False).reset_index(drop=True)


def make_display_profile(profile_dict):
    display_profile = {
        FEATURE_LABELS[k]: pretty_level(v) for k, v in profile_dict.items()
    }
    return pd.DataFrame([display_profile])


def make_display_combinations(scored_df):
    display_df = scored_df.copy()

    for col in FEATURES:
        display_df[col] = display_df[col].map(pretty_level)

    display_df = display_df.rename(columns=FEATURE_LABELS)
    display_df["Predicted Class"] = display_df["predicted_class"].map(pretty_level)
    display_df["Predicted Risk"] = display_df["predicted_risk"].round(4)

    keep_cols = [FEATURE_LABELS[col] for col in FEATURES] + ["Predicted Class", "Predicted Risk"]
    return display_df.rename(
        columns={
            "predicted_class": "Predicted Class",
            "predicted_risk": "Predicted Risk"
        }
    )[keep_cols]

# Load and train

try:
    train_df, test_df = load_data(TRAIN_FILE, TEST_FILE)
    train_clean, X_train, y_train, class_labels, category_levels = prepare_training_data(train_df)
    nb_model = fit_model(X_train, y_train)
except Exception as e:
    st.error(f"Failed to load or prepare data: {e}")
    st.stop()

# Sidebar inputs

st.sidebar.header("Select Feature Profile")

selected_profile = {}
for col in FEATURES:
    raw_options = category_levels[col]
    display_options = [pretty_level(x) for x in raw_options]

    selected_display = st.sidebar.selectbox(
        label=FEATURE_LABELS[col],
        options=display_options,
        index=0
    )

    # map display choice back to raw stored value
    reverse_map = {pretty_level(raw): raw for raw in raw_options}
    selected_profile[col] = reverse_map[selected_display]

predict_button = st.sidebar.button("Predict Risk", type="primary")

# --------------------------------------------------
# Top summary
# --------------------------------------------------
col1, col2 = st.columns([1, 1])

with col1:
    st.subheader("Selected Profile")
    st.dataframe(make_display_profile(selected_profile), use_container_width=True)

with col2:
    st.subheader("Model Information")
    st.write(f"**Classes:** {class_labels}")
    st.write(f"**Positive class:** {POS_LABEL}")
    st.write(f"**Training rows:** {len(train_clean):,}")

# Prediction

if predict_button:
    try:
        profile_df, X_profile = encode_profile(selected_profile, category_levels)
        result = predict_profile_risk(nb_model, X_profile, class_labels, POS_LABEL)

        st.markdown("---")
        st.subheader("Prediction Result")

        risk_pct = result["predicted_risk"] * 100

        if risk_pct < 20:
            risk_band = "Low"
            band_color = "green"
        elif risk_pct < 50:
            risk_band = "Moderate"
            band_color = "orange"
        else:
            risk_band = "High"
            band_color = "red"

        m1, m2, m3 = st.columns(3)
        with m1:
            st.metric("Predicted Class", pretty_level(result["predicted_class"]))
        with m2:
            st.metric("Predicted Risk of VAE", f"{risk_pct:.2f}%")
        with m3:
            st.markdown(
                f"**Risk Band:** <span style='color:{band_color}; font-weight:700'>{risk_band}</span>",
                unsafe_allow_html=True
            )

        prob_df = pd.DataFrame({
            "Class": [pretty_level(k) for k in result["all_probabilities"].keys()],
            "Probability": list(result["all_probabilities"].values())
        })
        prob_df["Probability"] = prob_df["Probability"].round(4)

        st.write("### Class Probabilities")
        st.dataframe(prob_df, use_container_width=True)

    except Exception as e:
        st.error(f"Prediction failed: {e}")

# Full combinations

st.markdown("---")
st.subheader("Explore All Possible Feature Combinations")

show_all = st.checkbox("Show full ranked combination table")
top_n = st.slider("Top rows to display", min_value=5, max_value=100, value=20, step=5)

if show_all:
    try:
        combo_df = build_all_combinations(category_levels)
        scored_df = score_all_combinations(nb_model, combo_df, category_levels, class_labels, POS_LABEL)
        display_scored_df = make_display_combinations(scored_df)

        st.write(f"Total combinations scored: **{len(display_scored_df):,}**")
        st.dataframe(display_scored_df.head(top_n), use_container_width=True)

        csv = display_scored_df.to_csv(index=False).encode("utf-8")
        st.download_button(
            label="Download full risk table as CSV",
            data=csv,
            file_name="ventrisk_all_combinations.csv",
            mime="text/csv"
        )

    except Exception as e:
        st.error(f"Could not generate full combination table: {e}")

# Footer

st.markdown("---")
st.caption(
    "Foundational study: Barnett WR, Bassett J, Jaenke C, Holtzapple Z, "
    "Boyinepally K, Back W, Maqsood A, Safi F, Assaly R. Detection of "
    "ventilator-associated events among adults: comparing a naïve Bayes "
    "classifier and logistic regression. Translation: The University of Toledo "
